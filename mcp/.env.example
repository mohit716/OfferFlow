# Base URL of the running OfferFlow API
OFFERFLOW_API_URL=http://localhost:5000/api

# Auth option 1: paste an existing JWT (from the app / login response)
# OFFERFLOW_TOKEN=eyJhbGciOi...

# Auth option 2 (recommended for local use): let the MCP log in for you
OFFERFLOW_EMAIL=you@example.com
OFFERFLOW_PASSWORD=your-password
