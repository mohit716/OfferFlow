PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/offerflow
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Short-lived access token lifetime (in-memory on the client).
ACCESS_TOKEN_TTL=15m
# Long-lived, revocable refresh token lifetime (httpOnly cookie), in days.
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGIN=http://localhost:5173
